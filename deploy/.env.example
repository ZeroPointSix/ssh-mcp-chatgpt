# ChatGPT / remote MCP deployment example. Do not commit real values.

# HTTP listener inside the Node process.
PORT=3000
NODE_ENV=production

# Public HTTPS origin used only as a fallback for local/direct requests.
# OAuth discovery normally follows the incoming Host / X-Forwarded-* headers.
# OAUTH_BASE_URL=https://ssh-mcp.example.com
# Human-entered secret shown on the /authorize page during ChatGPT OAuth login.
OAUTH_LOGIN_SECRET=change-me-to-random-login-secret
# ChatGPT Connector fixed client id (empty disables bootstrap)
# OAUTH_BOOTSTRAP_CLIENT_ID=mcp-client-chatgpt
# OAUTH_BOOTSTRAP_REDIRECT_URI_PREFIXES=https://chatgpt.com/connector/oauth/

# Optional static bearer token for non-ChatGPT API clients and operations.
# ChatGPT connector setup should use OAuth above.
SSH_MCP_HTTP_TOKEN=change-me-to-random-api-token

# ChatGPT browser origins allowed when an Origin header is present.
ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com

# Server-side SSH target. Do not put these credentials into ChatGPT prompts.
SSH_MCP_HOST=example.com
SSH_MCP_PORT=22
SSH_MCP_USER=deploy
# Choose exactly one auth method:
SSH_MCP_PASSWORD=
# SSH_MCP_PRIVATE_KEY can contain literal newlines or escaped \n sequences.
SSH_MCP_PRIVATE_KEY=
# Or mount a key file and point to it.
SSH_MCP_KEY=

# Sudo is optional. Leave disabled unless the target workflow really needs it.
SSH_MCP_DISABLE_SUDO=1
SSH_MCP_SUDO_PASSWORD=

# Command and audit controls.
# Use a positive integer to enforce a hard command length cap.
SSH_MCP_MAX_CHARS=none
# Return a background job_id after this many milliseconds while the command keeps running.
SSH_MCP_EXEC_EXPIRE_TIME_MS=55000
# Optional hard kill deadline for background commands; set a positive integer to enable.
SSH_MCP_EXEC_KILL_TIME_MS=none
SSH_MCP_DATA_DIR=/srv/ssh-mcp-chatgpt/data
SSH_MCP_TOOL_CALL_LOG_ENABLED=1
SSH_MCP_TOOL_CALL_NOTE_REQUIRED=0
